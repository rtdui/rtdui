{
  "name": "@rtdui/shiki-highlight",
  "version": "6.0.1",
  "description": "React code highlight component based on shiki",
  "types": "./lib/index.d.ts",
  "main": "./cjs/index.cjs",
  "module": "./esm/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.ts",
        "default": "./esm/index.mjs"
      },
      "require": {
        "types": "./lib/index.d.ts",
        "default": "./cjs/index.cjs"
      }
    }
  },
  "keywords": [
    "react",
    "components",
    "library",
    "ui",
    "ui-kit",
    "highlight",
    "shiki"
  ],
  "author": "fu zhong wei <jackyleefzw@163.com>",
  "license": "MIT",
  "homepage": "https://rtdui.com/",
  "sideEffects": [
    "*.css"
  ],
  "repository": {
    "url": "https://github.com/rtdui/rtdui.git",
    "type": "git",
    "directory": "packages/shiki-highlight"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "dependencies": {
    "@shikijs/colorized-brackets": "catalog:",
    "@shikijs/transformers": "catalog:",
    "@shikijs/types": "catalog:",
    "shiki": "catalog:",
    "@tabler/icons-react": "catalog:"
  },
  "peerDependencies": {
    "@rtdui/core": "workspace:*",
    "@rtdui/hooks": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
